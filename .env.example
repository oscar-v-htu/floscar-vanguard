# Server
HOST=0.0.0.0
PORT=3000
COOKIE_SECURE=false
SESSION_TTL_MS=86400000
DATA_DIR=./data

# Password hardening
# Set this to a long random secret in production.
PASSWORD_PEPPER=replace-with-a-long-random-secret

# Login rate limiting
LOGIN_WINDOW_MS=60000
LOGIN_MAX_ATTEMPTS=10
LOGIN_BLOCK_MS=300000

# Registration rate limiting
REGISTER_WINDOW_MS=60000
REGISTER_MAX_ATTEMPTS=5
REGISTER_BLOCK_MS=600000

# Download rate limiting
DOWNLOAD_WINDOW_MS=60000
DOWNLOAD_MAX_ATTEMPTS=30
DOWNLOAD_BLOCK_MS=300000
